# Puerto del servidor (default: 4321)
PORT=4321

# Directorio donde se guardan data.json, agents.json, campaigns.json
# Si se omite, usa el mismo directorio que server.js
# DATA_DIR=/ruta/a/datos

# --- Integración MikroWisp (lookup puntual por cédula) ---
# El token solo permite CONSULTAR un cliente a la vez, no listar toda la cartera.
# Por eso la cartera se carga con import CSV y este token sirve para refrescar
# un cliente (botón "Actualizar desde MikroWisp" en el panel de llamada).
# Si ambas variables están vacías, el botón no aparece.
# URL base de la API de MikroWisp / proxy (hasta /api/v1, sin /GetClientsDetails)
MIKROWISP_API_URL=https://proxy.valnetrd.com/api/v1
# Token de API generado en MikroWisp (Configuración del Sistema -> API).
# Es una clave larga, NO tu correo. Tratalo como contraseña: nunca subir a git.
MIKROWISP_TOKEN=
