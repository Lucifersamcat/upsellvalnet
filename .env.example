# Puerto del servidor (default: 4321)
PORT=4321

# Directorio donde se guardan data.json, agents.json, campaigns.json
# Si se omite, usa el mismo directorio que server.js
# DATA_DIR=/ruta/a/datos

# --- Integración MikroWisp (sincronización de clientes) ---
# URL del proxy a la API de MikroWisp (incluye hasta /api/v1)
MIKROWISP_API_URL=https://proxy.valnetrd.com/api/v1
# Token de API generado en MikroWisp (Configuración del Sistema -> API).
# Es una clave larga, NO tu correo. Tratalo como contraseña: nunca subir a git.
MIKROWISP_TOKEN=

# La integración MikroWisp ahora se configura desde la app (Admin -> API).
# apitools.json guarda endpoint/auth/token; estas variables quedan como referencia.
